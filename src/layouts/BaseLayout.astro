---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Elixir Companies',
  description = 'A curated directory of companies using Elixir in production.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon/favicon-16x16.png" />
    <link rel="manifest" href="/images/favicon/site.webmanifest" />
    <link rel="mask-icon" href="/images/favicon/safari-pinned-tab.svg" color="#7C6E8A" />
    <meta name="theme-color" content="#4A365F" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/elixircompanies_logo.png" />
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 dark:bg-elixir-950">
    <nav class="sticky top-0 z-50 bg-white/80 dark:bg-elixir-950/80 backdrop-blur-lg border-b border-gray-200 dark:border-elixir-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-3 group">
            <img src="/images/elixircompanies_logo.png" alt="Elixir Companies" class="h-8 w-auto" />
            <span class="font-display font-bold text-lg text-elixir-700 dark:text-white group-hover:text-accent transition-colors">
              Elixir Companies
            </span>
          </a>

          <div class="hidden md:flex items-center gap-6">
            <a href="/" class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-accent transition-colors">
              Home
            </a>
            <a href="/companies" class="text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-accent transition-colors">
              Companies
            </a>
            <a
              href="https://github.com/beam-community/elixir-companies"
              target="_blank"
              rel="noopener"
              class="btn-primary text-sm !px-4 !py-2"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
              Add Your Company
            </a>
          </div>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-elixir-800"
            aria-label="Toggle menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <div class="flex flex-col gap-2">
            <a href="/" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-elixir-800">
              Home
            </a>
            <a href="/companies" class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-elixir-800">
              Companies
            </a>
            <a
              href="https://github.com/beam-community/elixir-companies"
              target="_blank"
              rel="noopener"
              class="px-3 py-2 rounded-lg text-sm font-medium text-accent hover:bg-accent/10"
            >
              Add Your Company
            </a>
          </div>
        </div>
      </div>
    </nav>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-elixir-700 dark:bg-elixir-950 text-white mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <img src="/images/elixircompanies_logo.png" alt="Elixir Companies" class="h-8 w-auto brightness-200" />
              <span class="font-display font-bold text-lg">Elixir Companies</span>
            </div>
            <p class="text-elixir-200 text-sm">
              A curated directory of companies using Elixir in production, maintained by the community.
            </p>
          </div>
          <div>
            <h3 class="font-display font-semibold mb-4">Links</h3>
            <ul class="space-y-2 text-sm text-elixir-200">
              <li><a href="/companies" class="hover:text-white transition-colors">Browse Companies</a></li>
              <li><a href="https://github.com/beam-community/elixir-companies" target="_blank" rel="noopener" class="hover:text-white transition-colors">GitHub Repository</a></li>
              <li><a href="https://elixir-lang.org" target="_blank" rel="noopener" class="hover:text-white transition-colors">Elixir Language</a></li>
            </ul>
          </div>
          <div>
            <h3 class="font-display font-semibold mb-4">Community</h3>
            <p class="text-elixir-200 text-sm">
              Part of the <a href="https://github.com/beam-community" target="_blank" rel="noopener" class="underline hover:text-white">BEAM Community</a> ecosystem.
            </p>
          </div>
        </div>
        <div class="border-t border-elixir-600 mt-8 pt-8 text-center text-elixir-300 text-sm">
          Built with Astro. Powered by the Elixir community.
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
    </script>
  </body>
</html>
